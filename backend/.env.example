# Database — Supabase session pooler URL
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-X-ap-northeast-1.pooler.supabase.com:5432/postgres
DATABASE_DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-X-ap-northeast-1.pooler.supabase.com:5432/postgres

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development

# Scheduler — generate with: python -c "import secrets; print(secrets.token_hex(24))"
INTERNAL_JOB_SECRET=

# AI Chat — get your key at console.groq.com
GROQ_API_KEY=gsk_...

# Email — get your key at resend.com (free: 3,000 emails/month)
# Without a custom domain, EMAIL_SENDER must be: onboarding@resend.dev
# With a custom domain: YourApp <noreply@yourdomain.com>
RESEND_API_KEY=re_...
EMAIL_SENDER=RentEase <onboarding@resend.dev>
